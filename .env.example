# Copy this file to .env and fill in your values
# cp .env.example .env

# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Database — SQLite is fine for small teams, switch to PostgreSQL for scale
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///kartsystem.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://kartsystem_user:password@localhost/kartsystem_db

# Flask environment
FLASK_ENV=production

# Default admin password (only used when seeding fresh database)
ADMIN_PASSWORD=change-me-immediately
